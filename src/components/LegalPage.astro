---
import { withBase } from "../lib/paths";

interface LegalLink {
  href: string;
  label: string;
}

type LegalParagraph = string | {
  before: string;
  link: LegalLink;
  after: string;
};

interface LegalSection {
  heading: string;
  body: LegalParagraph[];
}

interface Props {
  title: string;
  updated: string;
  sections: LegalSection[];
}

const { title, updated, sections } = Astro.props;
---

<section class="page-hero compact">
  <p class="eyebrow">Lingüa Player</p>
  <h1>{title}</h1>
  <p>{updated}</p>
</section>

<section class="legal-content">
  <article class="legal-document">
    {sections.map((section) => (
      <div class="legal-section">
        <h2>{section.heading}</h2>
        {section.body.map((paragraph) => (
          typeof paragraph === "string" ? (
            <p>{paragraph}</p>
          ) : (
            <p>
              {paragraph.before}
              <a href={withBase(paragraph.link.href)}>{paragraph.link.label}</a>
              {paragraph.after}
            </p>
          )
        ))}
      </div>
    ))}
  </article>
</section>
