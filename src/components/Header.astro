---
import { nav } from "../data/site";
import { alternateLocalePath, withBase } from "../lib/paths";

interface Props {
  locale: "en" | "ru";
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const switchPath = alternateLocalePath(currentPath, locale);
const currentLanguage = locale === "en"
  ? { flag: "🇺🇸", label: "EN", name: "English" }
  : { flag: "🇷🇺", label: "RU", name: "Русский" };
const nextLanguage = locale === "en"
  ? { flag: "🇷🇺", label: "RU", name: "Русский" }
  : { flag: "🇺🇸", label: "EN", name: "English" };
const homePath = locale === "en" ? "/" : "/ru/";
---

<header class="site-header">
  <a class="brand" href={withBase(homePath)} aria-label="Lingüa Player home">
    <img src={withBase("/images/app-icon.jpg")} alt="" />
    <span>Lingüa Player</span>
  </a>

  <nav class="main-nav" aria-label={locale === "en" ? "Main navigation" : "Основная навигация"}>
    {nav[locale].map((item) => (
      <a href={withBase(item.href)} class:list={{ active: item.href === currentPath }}>
        {item.label}
      </a>
    ))}
  </nav>

  <details class="language-menu">
    <summary aria-label={locale === "en" ? "Current language: English" : "Текущий язык: русский"}>
      <span>{currentLanguage.flag}</span>
      <span>{currentLanguage.label}</span>
    </summary>
    <div class="language-options">
      <a href={withBase(switchPath)}>
        <span>{nextLanguage.flag}</span>
        <span>{nextLanguage.name}</span>
      </a>
    </div>
  </details>
</header>
