---
interface Props {
  title: string;
  authors: string;
  year: string;
  publication: string;
  url: string;
  doi: string;
  summary: string;
}

const { title, authors, year, publication, url, doi, summary } = Astro.props;
---

<article class="research-card">
  <div class="research-meta">{authors} · {year} · {publication}</div>
  <h2>{title}</h2>
  <p>{summary}</p>
  <a href={url} target="_blank" rel="noopener noreferrer">DOI: {doi}</a>
</article>
