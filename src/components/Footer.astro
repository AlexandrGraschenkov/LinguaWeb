---
import { contactEmail, legalLinks } from "../data/site";
import { withBase } from "../lib/paths";

interface Props {
  locale: "en" | "ru";
}

const { locale } = Astro.props;
---

<footer class="site-footer">
  <div>
    <strong>Lingüa Player</strong>
  </div>
  <nav aria-label={locale === "en" ? "Legal links" : "Юридические ссылки"}>
    {legalLinks[locale].map((item) => (
      <a href={withBase(item.href)}>{item.label}</a>
    ))}
    <a href={`mailto:${contactEmail}`}>{locale === "en" ? "Contact" : "Контакты"}</a>
  </nav>
</footer>
