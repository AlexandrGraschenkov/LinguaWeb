---
import Layout from "../../components/Layout.astro";
import CTA from "../../components/CTA.astro";
import Icon from "../../components/Icon.astro";
import { home } from "../../data/home";
import { withBase } from "../../lib/paths";

const locale = "ru";
const content = home.ru;
const featureIcons = ["languages", "offline", "gesture", "captions", "repeat", "film"] as const;
---

<Layout
  title="Lingüa Player - видеоплеер для изучения языков"
  description="Учите языки через онлайн-видео, YouTube, оффлайн-файлы, перевод субтитров, OCR, карточки и оффлайн-перевод."
  locale={locale}
  currentPath="/ru/"
>
  <section class="hero">
    <div class="hero-copy">
      <h1>{content.title}</h1>
      <p class="lead">{content.lead}</p>
      <CTA label={content.cta} />
    </div>

    <div class="phone-stage" aria-hidden="true">
      <div class="phone-stack">
        <img src={withBase("/images/onboarding-series.jpg")} alt="" />
        <img src={withBase("/images/onboarding-subtitles.jpg")} alt="" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <h2>От просмотра к запоминанию, не выходя из видео.</h2>
      </div>
      <p class="section-note">Lingüa Player держит учебный цикл рядом с контентом: понять момент, сохранить слово, повторить его позже.</p>
    </div>

    <div class="feature-grid">
      {content.sections.map((section) => (
        <article class="feature-card">
          <div>
            <h3>{section.title}</h3>
            <p>{section.text}</p>
          </div>
          <img src={withBase(section.image)} alt="" loading="lazy" />
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <h2>{content.featuresTitle}</h2>
      </div>
      <p class="section-note">Используйте реальные видео как input и выбирайте, сколько помощи нужно от субтитров, перевода и повторения.</p>
    </div>
    <div class="pill-grid">
      {content.features.map((feature, index) => (
        <div class="pill">
          <Icon name={featureIcons[index]} />
          <span>{feature}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
