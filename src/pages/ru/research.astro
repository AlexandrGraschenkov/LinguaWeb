---
import Layout from "../../components/Layout.astro";
import ResearchCard from "../../components/ResearchCard.astro";
import { research, researchIntro } from "../../data/research";
---

<Layout
  title="Исследования - Lingüa Player"
  description="Исследования о том, как видео, субтитры, работа с лексикой и самостоятельные мобильные занятия помогают изучать иностранный язык."
  locale="ru"
  currentPath="/ru/research.html"
>
  <section class="page-hero">
    <h1>{researchIntro.ru.title}</h1>
    <p class="lead">{researchIntro.ru.lead}</p>
  </section>

  <section class="section">
    <div class="research-grid">
      {research.map((item) => (
        <ResearchCard
          title={item.ruShortTitle}
          authors={item.authors}
          year={item.year}
          publication={item.publication}
          url={item.url}
          bullets={item.ruBullets}
        />
      ))}
    </div>
  </section>
</Layout>
