---
import Layout from "../components/Layout.astro";
import Icon from "../components/Icon.astro";
import { contactEmail, refundUrl, subscriptionsUrl } from "../data/site";
---

<Layout
  title="Support - Lingüa Player"
  description="Contact Lingüa Player support and find quick troubleshooting steps."
  locale="en"
  currentPath="/support_page.html"
>
  <section class="page-hero compact support-hero">
    <h1>Need help with Lingüa Player?</h1>
    <p>Send a short description of the issue, your device model, iOS version, and app version. Screenshots or screen recordings help when the problem is visual.</p>
  </section>

  <section class="section">
    <div class="support-grid">
      <article class="support-card">
        <div class="card-title">
          <Icon name="mail" />
          <h2>Contact</h2>
        </div>
        <p>Email support directly and include the video source or file type if the issue is playback-related.</p>
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </article>
      <article class="support-card">
        <div class="card-title">
          <Icon name="credit-card" />
          <h2>How to cancel a subscription</h2>
        </div>
        <p>Open the App Store on your iPhone, tap your profile icon, then choose Subscriptions. Find Lingüa Player in the list of active subscriptions and select the cancellation option.</p>
        <a href={subscriptionsUrl} target="_blank" rel="noopener noreferrer">Manage subscriptions</a>
      </article>
      <article class="support-card">
        <div class="card-title">
          <Icon name="repeat" />
          <h2>How to request a refund</h2>
        </div>
        <p>If you were charged by mistake, the refund request must be submitted to Apple. Sign in on Apple's website, choose the purchase, and request a refund there.</p>
        <a href={refundUrl} target="_blank" rel="noopener noreferrer">Request refund</a>
      </article>
    </div>
  </section>
</Layout>
