---
import Layout from "../components/Layout.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import { faq } from "../data/faq";
---

<Layout
  title="FAQ - Lingüa Player"
  description="Answers about Lingüa Player online video, offline video, subtitles, translation, OCR, flashcards, privacy, and support."
  locale="en"
  currentPath="/faq.html"
>
  <section class="page-hero compact">
    <h1>Questions people usually ask before using Lingüa Player.</h1>
    <p>Short answers about video sources, offline playback, translators, flashcards, and privacy.</p>
  </section>
  <FAQAccordion items={faq.en} />
</Layout>
